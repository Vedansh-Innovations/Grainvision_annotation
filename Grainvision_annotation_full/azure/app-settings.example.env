# Reference of the environment variables the deploy script sets on the Web App.
# (deploy.sh fills these automatically — this file is just documentation.)

# Core Django
DEBUG=False
SECRET_KEY=<50+ random chars>
ALLOWED_HOSTS=<app>.azurewebsites.net
CSRF_TRUSTED_ORIGINS=https://<app>.azurewebsites.net
SECURE_SSL_REDIRECT=True

# Database (Azure Database for PostgreSQL Flexible Server)
USE_POSTGRES=True
POSTGRES_DB=grainvision
POSTGRES_USER=gvadmin
POSTGRES_PASSWORD=<secret>
POSTGRES_HOST=<server>.postgres.database.azure.com
POSTGRES_PORT=5432
POSTGRES_SSLMODE=require

# Media (Azure Files mounted at /app/media). Keep USE_S3 off.
USE_S3=False
SERVE_MEDIA=True

# Segmentation engine (App Service is CPU-only)
SAM2_ENABLED=True
SAM2_REQUIRED=True
SAM2_DEVICE=cpu
SAM2_POINTS_PER_SIDE=16

# Server
WEBSITES_PORT=8000
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=300

# First-boot admin (gets the Admin role automatically)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=<secret>
DJANGO_SUPERUSER_EMAIL=admin@example.com

# Optional: load demo mandis/commodities/users on first boot
SEED_DEMO=false
